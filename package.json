{
  "name": "synthr-web-public",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "npm --prefix apps/web-public run dev",
    "build": "node scripts/hostinger-build-web-public.mjs",
    "start": "npm --prefix apps/web-public run start",
    "hostinger:build": "node scripts/hostinger-build-web-public.mjs",
    "hostinger:start": "npm --prefix apps/web-public run start",
    "web-admin:build": "npm --prefix apps/web-admin install && npm --prefix apps/web-admin run build",
    "api:build": "pnpm --filter @synthr/api build"
  },
  "dependencies": {
    "@sentry/react": "^10.46.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "yet-another-react-lightbox": "^3.30.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.4",
    "typescript": "^6.0.2"
  }
}
