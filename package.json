{
  "name": "synthr",
  "private": true,
  "scripts": {
    "postinstall": "npm ci --prefix apps/web-public",
    "dev": "pnpm -r --parallel dev",
    "build": "npm run build --prefix apps/web-public && node scripts/sync-web-public-next.mjs",
    "build:all": "pnpm -r build",
    "start": "npm run start --prefix apps/web-public",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @synthr/api db:migrate",
    "db:seed": "pnpm --filter @synthr/api db:seed",
    "web-public:install": "npm ci --prefix apps/web-public",
    "web-public:build": "npm run build --prefix apps/web-public",
    "web-public:start": "npm run start --prefix apps/web-public",
    "hostinger:build": "npm run web-public:build",
    "hostinger:start": "npm run web-public:start"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "prisma": "^6.0.0",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "@types/bcryptjs": "^2.4.6",
    "ts-node": "^10.9.2"
  }
}
